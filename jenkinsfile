pipeline {
    agent any

    environment {
        TEST_SERVER_IP = "172.20.20.101"  // Ensure this matches your test server's IP
        REPO_URL = "git@github.com:Saliu40/projCert.git"
        DOCKER_IMAGE_NAME = "php-app"
        CONTAINER_NAME = "php-app-container"
    }

    stages {
        
        stage('Job 1: Install Puppet Agent on Test Server') {
            steps {
                script {
                    sh '''
                    ssh vagrant@${TEST_SERVER_IP} "sudo apt update && sudo apt install -y puppet-agent"
                    ssh vagrant@${TEST_SERVER_IP} "sudo systemctl start puppet && sudo systemctl enable puppet"
                    '''
                }
            }
        }

        stage('Job 2: Configure Docker using Ansible') {
            steps {
                script {
                    // Ensure inventory file is correctly created
                    writeFile file: 'inventory', text: "${TEST_SERVER_IP}"

                    // Ensure playbook filename matches the fixed version
                    writeFile file: 'install_docker.yml', text: '''
                    ---
                    - name: Install Docker on Test Server
                      hosts: all
                      become: yes
                      tasks:
                        - name: Install prerequisites
                          apt:
                            name:
                              - apt-transport-https
                              - ca-certificates
                              - curl
                              - software-properties-common
                            state: present
                            update_cache: yes

                        - name: Add Docker GPG Key
                          shell: curl -fsSL https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg

                        - name: Add Docker Repository
                          shell: echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null

                        - name: Update apt cache
                          apt:
                            update_cache: yes

                        - name: Install Docker
                          apt:
                            name: docker-ce
                            state: present

                        - name: Start Docker Service
                          service:
                            name: docker
                            state: started
                            enabled: yes
                    '''
                    
                    // Run Ansible playbook
                    sh '''
                    ansible-playbook -i inventory -u vagrant --private-key ~/.vagrant.d/insecure_private_key install_docker.yml
                    '''
                }
            }
        }

        stage('Job 3: Pull Code, Build, and Deploy Docker Container') {
            steps {
                script {
                    sh '''
                    ssh vagrant@${TEST_SERVER_IP} "[ -d ~/php-app ] || git clone ${REPO_URL} ~/php-app"
                    ssh vagrant@${TEST_SERVER_IP} "cd ~/php-app && git pull"
                    ssh vagrant@${TEST_SERVER_IP} "cd ~/php-app && docker build -t ${DOCKER_IMAGE_NAME} ."
                    ssh vagrant@${TEST_SERVER_IP} "docker stop ${CONTAINER_NAME} || true"
                    ssh vagrant@${TEST_SERVER_IP} "docker rm ${CONTAINER_NAME} || true"
                    ssh vagrant@${TEST_SERVER_IP} "docker run -d --name ${CONTAINER_NAME} -p 8080:80 ${DOCKER_IMAGE_NAME}"
                    '''
                }
            }
        }

        stage('Job 4: Cleanup on Failure') {
            when {
                expression { currentBuild.result == 'FAILURE' }
            }
            steps {
                script {
                    sh '''
                    ssh vagrant@${TEST_SERVER_IP} "docker stop ${CONTAINER_NAME} || true"
                    ssh vagrant@${TEST_SERVER_IP} "docker rm ${CONTAINER_NAME} || true"
                    '''
                }
            }
        }
    }

    post {
        success {
            echo "Deployment completed successfully!"
        }
        failure {
            echo "Pipeline failed! Container removed from Test Server."
        }
    }
}
